# Dev-auth bypass mode — used by `npm run dev:bypass` (vite --mode devauth).
# Renders the authenticated app WITHOUT a Supabase login so Claude Code / Codex
# (and humans) can see authed pages directly in a preview. Non-secret: only
# flags + a localhost API URL, so it is safe to commit. Pair it with a backend
# running in dev mode (NEXUSREACH_AUTH_MODE=dev + NEXUSREACH_DEV_AUTH_BYPASS_ENABLED=true).
# This file overrides .env in `devauth` mode only; plain `npm run dev` is untouched.
VITE_AUTH_MODE=dev
VITE_DEV_AUTH_BYPASS_ENABLED=true
VITE_DEV_USER_EMAIL=dev@nexusreach.local
VITE_API_URL=http://localhost:8000
VITE_APP_ENVIRONMENT=development
VITE_ANALYTICS_ENABLED=false
