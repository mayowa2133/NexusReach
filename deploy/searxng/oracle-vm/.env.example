# Oracle VM SearXNG + Caddy config. Copy to `.env` (never commit the real .env).

# A long random string. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SEARXNG_SECRET=

# Your domain pointing at this VM's public IP (a free DuckDNS subdomain works).
SEARXNG_DOMAIN=yourname.duckdns.org

# Basic Auth the backend will use. The USER + plaintext password go into the
# backend's NEXUSREACH_SEARXNG_BASE_URL; Caddy only stores the bcrypt HASH.
SEARXNG_BASICAUTH_USER=nexus
# Generate the hash (you'll paste the *plaintext* into the backend URL):
#   docker run --rm caddy caddy hash-password --plaintext 'YOUR_PASSWORD'
SEARXNG_BASICAUTH_HASH=
