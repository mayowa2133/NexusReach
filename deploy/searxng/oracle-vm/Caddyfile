# Caddy reverse proxy: HTTPS (auto Let's Encrypt) + Basic Auth in front of SearXNG.
#
# `basic_auth` is the directive name on Caddy v2.8+. On older Caddy v2 it is
# `basicauth` (one word) — rename it if your image is older than 2.8.
# The hash is a bcrypt hash produced by:
#   docker run --rm caddy caddy hash-password --plaintext 'YOUR_PASSWORD'
{$SEARXNG_DOMAIN} {
	basic_auth {
		{$SEARXNG_BASICAUTH_USER} {$SEARXNG_BASICAUTH_HASH}
	}
	reverse_proxy searxng:8080
}
