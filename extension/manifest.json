{
  "manifest_version": 3,
  "name": "Solomon Companion",
  "version": "1.0.0",
  "description": "Solomon job-search companion: capture hiring teams from pages you view, sync your own LinkedIn network, autofill applications.",
  "permissions": ["storage", "activeTab", "tabs", "alarms", "notifications"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:5173/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:4173/*",
    "http://127.0.0.1:4173/*",
    "https://boards.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://jobs.ashbyhq.com/*",
    "https://apply.workable.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://jobs.apple.com/*",
    "https://*.careers-page.com/*",
    "https://www.linkedin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "http://localhost:4173/*",
        "http://127.0.0.1:4173/*"
      ],
      "js": ["app-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://boards.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://jobs.ashbyhq.com/*",
        "https://apply.workable.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://jobs.apple.com/*",
        "https://*.careers-page.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": ["linkedin-content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
